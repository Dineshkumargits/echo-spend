# Copy to .env and fill in your values. Never commit .env to git.

# App identity
APP_BUNDLE_ID=com.echospending.app

# On-device AI model (downloaded once on first launch)
AI_MODEL_URL=https://huggingface.co/ADKDinesh/Qwen2.5-1.5B-SMS-Finance-Parser-GGUF/resolve/main/qwen2.5-1.5b-sms-finance-parser-q4_k_m.gguf

# Google OAuth (from Google Cloud Console)
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
